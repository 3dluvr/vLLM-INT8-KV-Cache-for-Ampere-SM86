+@triton.jit
+def _fp8_e4m3_encode_to_int8(x):
+    x = x.to(tl.float32)
+
+    # bitcast float32 -> int32
+    raw = tl.inline_asm_elementwise(
+        "mov.b32 $0, $1;",
+        "=r,f",
+        [x],
+        dtype=tl.int32,
+        is_pure=True,
+        pack=1,
+    )
+
+    # extract FP32 fields
+    sign = (raw >> 31) & 1
+    exp = (raw >> 23) & 0xff
+    mant = raw & 0x7fffff
+
+    true_exp = exp - 127
+    fp8_exp = true_exp + 7
+
+    ax = tl.abs(x)
+
+    # zero
+    is_zero = (exp == 0) | (x == 0.0)
+
+    # E4M3 normal range
+    normal = true_exp >= -6
+
+    # normal mantissa: keep top 3 bits
+    mant3 = mant >> 20
+
+    # clamp exponent [1,14]
+    fp8_exp = tl.maximum(tl.minimum(fp8_exp, 14), 1)
+
+    normal_bits = (
+        (sign << 7)
+        | (fp8_exp << 3)
+        | mant3
+    )
+
+    # subnormal
+    sub_bits = (sign << 7) | tl.minimum(
+        (ax * 512.0 + 0.5).to(tl.int32),
+        7,
+    )
+
+    out = tl.where(normal, normal_bits, sub_bits)
+
+    # zero
+    out = tl.where(is_zero, 0, out)
+
+    # FP8_V_EMUL saturation
+    out = tl.where(
+        ax > 448.0,
+        (sign << 7) | 0x7e,
+        out,
+    )
+
+    return out.to(tl.int8)
+
