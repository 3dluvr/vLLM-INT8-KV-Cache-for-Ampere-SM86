new file mode 100644
index 000000000..d1b055d69
--- /dev/null
+++ b/vllm/v1/attention/per_layer_scales.py
@@ -0,0 +1,300 @@
+# SPDX-License-Identifier: Apache-2.0
+"""
+Per-layer KV cache scale management for INT8/FP8 quantization.
+
+Supports:
+- Recording K/V absmax per layer during calibration
+- Saving per-layer scales to JSON file
+- Loading per-layer scales from JSON file
+
+Environment variables:
+- VLLM_KV_SCALES_RECORD=1: Enable recording mode
+- VLLM_KV_SCALES_FILE=/path/to/scales.json: Load scales from file
+
+Usage:
+1. Calibration mode:
+   VLLM_KV_SCALES_RECORD=1 vllm serve ... --kv-cache-dtype int8 --calculate-kv-scales
+   # Run diverse prompts
+   # Scales are saved to /tmp/vllm_kv_scales.json on server shutdown
+
+2. Inference mode:
+   VLLM_KV_SCALES_FILE=/path/to/scales.json vllm serve ... --kv-cache-dtype int8
+"""
+
+import atexit
+import json
+import os
+import sys
+import threading
+from pathlib import Path
+from typing import Dict, Optional
+
+import torch
+
+from vllm.logger import init_logger
+
+logger = init_logger(__name__)
+
+# Global state for scale recording
+_lock = threading.Lock()
+_layer_stats: Dict[str, Dict[str, float]] = {}
+_scales_loaded: Dict[str, Dict[str, float]] = {}
+# NOTE: Check env vars dynamically to support subprocess environment inheritance
+_recording_enabled: Optional[bool] = None
+_scales_file: Optional[str] = None
+_scales_load_attempted = False
+
+
+def _get_recording_enabled() -> bool:
+    """Get recording enabled status, checking env var on first call."""
+    global _recording_enabled
+    if _recording_enabled is None:
+        _recording_enabled = os.getenv("VLLM_KV_SCALES_RECORD", "0") == "1"
+        if _recording_enabled:
+            logger.info("Per-layer KV scale recording ENABLED")
+    return _recording_enabled
+
+
+def _get_scales_file() -> str:
+    """Get scales file path, checking env var on first call."""
+    global _scales_file
+    if _scales_file is None:
+        _scales_file = os.getenv("VLLM_KV_SCALES_FILE", "")
+    return _scales_file
+
+
+def record_kv_absmax(layer_name: str, k_absmax: float, v_absmax: float) -> None:
+    """Record observed K/V absmax for a layer. Keeps track of maximum seen."""
+    if not _get_recording_enabled():
+        return
+
+    with _lock:
+        if layer_name not in _layer_stats:
+            _layer_stats[layer_name] = {
+                "k_absmax": 0.0,
+                "v_absmax": 0.0,
+                "num_updates": 0,
+            }
+
+        stats = _layer_stats[layer_name]
+        stats["k_absmax"] = max(stats["k_absmax"], k_absmax)
+        stats["v_absmax"] = max(stats["v_absmax"], v_absmax)
+        stats["num_updates"] += 1
+
+
+def get_recorded_stats() -> Dict[str, Dict[str, float]]:
+    """Get all recorded per-layer statistics."""
+    with _lock:
+        return dict(_layer_stats)
+
+
+def _get_tp_size_from_args() -> int:
+    """Safely extracts tensor_parallel_size from CLI args during teardown."""
+    args = sys.argv
+    
+    # Check for '--tensor-parallel-size' or the shorthand '-tp'
+    for i, arg in enumerate(args):
+        if arg in ("--tensor-parallel-size", "-tp"):
+            try:
+                # The value right after the flag is our size
+                return int(args[i + 1])
+            except (IndexError, ValueError):
+                pass
+                
+    # Also look for format like '--tensor-parallel-size=2'
+    for arg in args:
+        if arg.startswith("--tensor-parallel-size="):
+            try:
+                return int(arg.split("=")[1])
+            except (IndexError, ValueError):
+                pass
+
+    # If the flag isn't present, vLLM defaults to 1
+    return 1
+
+def _get_tp_rank_from_pid() -> str:
+    try:
+        # Read the process command line directly from Linux /proc
+        cmdline = Path(f"/proc/{os.getpid()}/cmdline").read_text().strip()
+        if "Worker_TP" in cmdline:
+            return int(cmdline[-1])
+    except Exception:
+        return None
+
+def _get_rank_from_process_name() -> int:
+    """Extracts the TP rank integer from the process title (e.g., VLLM::Worker_TP1)."""
+    try:
+        # check /proc/self/status which holds the modified runtime process Name
+        status_path = Path("/proc/self/status")
+        if status_path.exists():
+            for line in status_path.read_text().splitlines():
+                if line.startswith("Name:"):
+                    proc_name = line.split(":", 1)[1].strip()
+                    if "Worker_TP" in proc_name:
+                        # Extract everything after 'Worker_TP'
+                        rank_str = proc_name.split("Worker_TP")[1].strip()
+                        if rank_str.isdigit():
+                            return int(rank_str)
+    except Exception:
+        pass
+
+    try:
+        # fallback: check /proc/self/cmdline (null-separated arguments)
+        cmdline = Path("/proc/self/cmdline").read_text()
+        if "Worker_TP" in cmdline:
+            parts = cmdline.split("Worker_TP")
+            if len(parts) > 1:
+                rank_str = parts[1][0]
+                if rank_str.isdigit():
+                    return int(rank_str)
+    except Exception:
+        pass
+
+    # Default fallback to rank 0 if no match is found
+    return 0
+
+#
+# new save_sales accounting for TP dimension
+#
+def save_scales(output_path: Optional[str] = None) -> None:
+    # save recorded per-layer scales to JSON file.
+    if not _layer_stats:
+        logger.warning("No scales recorded, nothing to save")
+        return
+
+    tp_rank = _get_rank_from_process_name()
+    tp_size = _get_tp_size_from_args() 
+
+    if output_path is None:
+        output_path = os.getenv("VLLM_KV_SCALES_OUTPUT", "/tmp/vllm_kv_scales.json")
+
+    # dynamically apply filename adjustments in the same folder
+    path = Path(output_path)
+
+    path.parent.mkdir(parents=True, exist_ok=True)
+ 
+    # automatically adjust based on the detected TP size
+    if tp_rank is not None and tp_size > 1:
+        # If running TP 2, TP 4, etc., append the rank dynamically
+        # Result: /tmp/vllm_kv_scales_tp0.json, _tp1.json, etc.
+        path = path.with_name(f"{path.stem}_tp{tp_rank}{path.suffix}")
+    else:
+        # If running TP 1 (single GPU), keep the original clean filename
+        # Result: /tmp/vllm_kv_scales.json
+        pass
+
+    path.parent.mkdir(parents=True, exist_ok=True)
+
+    use_fp8_v = os.getenv("VLLM_INT8_V_FP8_EMUL", "0") == "1"
+    k_range = 127.0  # INT8 range
+    v_range = 448.0 if use_fp8_v else 127.0  # FP8-E4M3 or INT8 range
+
+    scales_data = {
+        "version": "1.1",  
+        "description": f"Per-layer K/V scales for INT8 KV cache (TP Rank {tp_rank})",
+        "k_range": k_range,
+        "v_range": v_range,
+        "fp8_v_emul": use_fp8_v,
+        "layers": {},
+    }
+
+    for layer_name, stats in sorted(_layer_stats.items()):
+        k_scale = stats["k_absmax"] / k_range if stats["k_absmax"] > 0 else 1.0
+        v_scale = stats["v_absmax"] / v_range if stats["v_absmax"] > 0 else 1.0
+
+        scales_data["layers"][layer_name] = {
+            "k_absmax": stats["k_absmax"],
+            "v_absmax": stats["v_absmax"],
+            "k_scale": k_scale,
+            "v_scale": v_scale,
+            "num_updates": stats["num_updates"],
+        }
+
+    path.write_text(json.dumps(scales_data, indent=2))
+    logger.info(f"[Rank {tp_rank}] Saved per-layer KV scales to: {path}")
+
+    # Print summary (now specific to this worker's shard)
+    k_absmax_list = [s["k_absmax"] for s in scales_data["layers"].values()]
+    v_absmax_list = [s["v_absmax"] for s in scales_data["layers"].values()]
+    logger.info(f"[Rank {tp_rank}] K absmax range: {min(k_absmax_list):.2f} - {max(k_absmax_list):.2f}")
+    logger.info(f"[Rank {tp_rank}] V absmax range: {min(v_absmax_list):.2f} - {max(v_absmax_list):.2f}")
+    v_ratio = max(v_absmax_list) / max(min(v_absmax_list), 1e-10)
+    logger.info(f"[Rank {tp_rank}] V variance ratio: {v_ratio:.1f}x")
+
+
+#
+# new save_sales accounting for TP dimension
+#
+def load_scales(scales_file: Optional[str] = None) -> bool:
+    global _scales_loaded
+
+    if scales_file is None:
+        scales_file = _get_scales_file()
+
+    if not scales_file:
+        return False
+
+    path = Path(scales_file)
+
+    # extract the unique worker rank from the non-truncated process name
+    tp_rank = _get_rank_from_process_name()
+    
+    # extract the overall TP size from sys.argv
+    tp_size = _get_tp_size_from_args()
+
+    # if TP is active, modify the path to target this worker's specific file
+    if tp_size > 1:
+        # Changes /tmp/vllm_kv_scales.json -> /tmp/vllm_kv_scales_tp1.json (for Worker 1)
+        path = path.with_name(f"{path.stem}_tp{tp_rank}{path.suffix}")
+
+    # read the file
+    if not path.exists():
+        logger.warning(f"[Rank {tp_rank}] Scales file not found: {path}")
+        return False
+
+    try:
+        data = json.loads(path.read_text())
+        _scales_loaded = data.get("layers", {})
+        logger.info(f"[Rank {tp_rank}] Loaded per-layer scales from: {path}")
+        logger.info(f"[Rank {tp_rank}] Number of layers: {len(_scales_loaded)}")
+        return True
+    except Exception as e:
+        logger.error(f"[Rank {tp_rank}] Failed to load scales from {path}: {e}")
+        return False
+
+
+def get_layer_scales(layer_name: str) -> Optional[Dict[str, float]]:
+    """Get pre-loaded scales for a specific layer."""
+    return _scales_loaded.get(layer_name)
+
+
+def has_loaded_scales() -> bool:
+    """Check if scales have been loaded from file."""
+    global _scales_load_attempted
+    # Try to load on first check
+    if not _scales_load_attempted:
+        _scales_load_attempted = True
+        scales_file = _get_scales_file()
+        logger.info(f"Checking for scales file: '{scales_file}'")
+        if scales_file:
+            load_scales(scales_file)
+            logger.info(f"Loaded {len(_scales_loaded)} layer scales")
+    return bool(_scales_loaded)
+
+
+def is_recording_enabled() -> bool:
+    """Check if recording mode is enabled."""
+    return _get_recording_enabled()
+
+
+# Auto-save on shutdown if recording was enabled
+def _atexit_save():
+    if _get_recording_enabled() and _layer_stats:
+        output_path = os.getenv("VLLM_KV_SCALES_OUTPUT", "/tmp/vllm_kv_scales.json")
+        save_scales(output_path)
+
+
+atexit.register(_atexit_save)
+
+# Auto-load scales if file specified - done lazily on first access
+# to support subprocess environment inheritance
